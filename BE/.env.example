# App
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production
SERVICE_TOKEN=your-service-token-for-editor-app

# Database — dùng tên service trong Docker, không phải localhost
DATABASE_URL=postgresql+asyncpg://kusshoes:kusshoes@db:5432/kusshoes

# Redis
REDIS_URL=redis://redis:6379/0

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_DAYS=30
SSO_TOKEN_EXPIRE_MINUTES=5

# Editor/3D worker (để trống khi chưa tích hợp service ngoài)
EDITOR_WORKER_URL=
EDITOR_WORKER_TIMEOUT_SECONDS=300

# Storage (MinIO local — dùng tên service trong Docker)
# Production dùng Cloudflare R2: xem .env.production.example
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=kusshoes
STORAGE_PUBLIC_URL=http://localhost:9000/kusshoes
STORAGE_REGION=us-east-1

# KIRI Engine (3D scan — để trống khi dev, cần khi port scan pipeline Phase 2)
KIRI_API_TOKEN=
KIRI_API_BASE_URL=https://api.kiriengine.app/api

# Email (SMTP — dùng cho OTP verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=noreply@kusshoes.vn

# Sentry (để trống khi dev)
SENTRY_DSN=

# Polar (billing) — https://polar.sh
POLAR_ACCESS_TOKEN=polar_oat_xxx
POLAR_WEBHOOK_SECRET=whsec_xxx        # Lấy từ Polar dashboard → Webhooks
POLAR_SERVER=sandbox                  # "sandbox" khi dev/test, "production" khi live
POLAR_SUCCESS_URL=http://localhost:5173/billing/success?checkout_id={CHECKOUT_ID}
