# ============================================================
# KusShoes BE — Production (DigitalOcean droplet + Neon + R2)
# Sao chép: cp .env.production.example .env.production rồi điền giá trị thật.
# KHÔNG commit file .env.production.
# ============================================================

# ==== App ====
APP_ENV=production
PUBLIC_WEB_URL=https://app.kusshoes.vn
# Sinh secret: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
SERVICE_TOKEN=CHANGE_ME_openssl_rand_hex_32

# ==== Database — Neon Postgres (managed, KHÔNG chạy trên droplet) ====
# console.neon.tech → project → Connection Details → chọn "Pooled connection"
# Đổi prefix postgresql:// thành postgresql+asyncpg:// và thêm ?ssl=require
# (asyncpg không nhận sslmode/channel_binding — chỉ dùng ssl=require)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?ssl=require

# ==== Redis (container nội bộ trên droplet — không phải dịch vụ ngoài) ====
REDIS_URL=redis://redis:6379/0

# ==== Google OAuth ====
# console.cloud.google.com → Credentials → thêm redirect URI production
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://api.kusshoes.vn/api/v1/auth/google/callback

# ==== JWT ====
ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_DAYS=30
SSO_TOKEN_EXPIRE_MINUTES=5

# ==== Editor/3D worker ====
EDITOR_WORKER_URL=
EDITOR_WORKER_TIMEOUT_SECONDS=300

# ==== Storage — Cloudflare R2 (managed, KHÔNG chạy MinIO trên droplet) ====
# dash.cloudflare.com → R2 → Manage R2 API Tokens → tạo token "Object Read & Write"
# ACCOUNT_ID nằm ở trang chủ R2 (góc phải)
STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=R2_ACCESS_KEY_ID
STORAGE_SECRET_KEY=R2_SECRET_ACCESS_KEY
STORAGE_BUCKET=kusshoes
STORAGE_REGION=auto
# Gắn custom domain cdn.kusshoes.vn cho bucket (R2 → bucket → Settings → Custom Domains)
STORAGE_PUBLIC_URL=https://cdn.kusshoes.vn

# ==== KIRI Engine (3D scan API — Phase 2) ====
# kiriengine.app → Developer API → nạp credit (tối thiểu 500 = $500), lấy token
KIRI_API_TOKEN=
KIRI_API_BASE_URL=https://api.kiriengine.app/api

# ==== Email (SMTP — OTP verification) ====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=noreply@kusshoes.vn

# ==== Sentry ====
SENTRY_DSN=

# ==== Polar (billing) ====
POLAR_ACCESS_TOKEN=polar_oat_xxx
POLAR_WEBHOOK_SECRET=whsec_xxx
POLAR_SERVER=production
POLAR_SUCCESS_URL=https://app.kusshoes.vn/billing/success?checkout_id={CHECKOUT_ID}
